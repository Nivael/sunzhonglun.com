---
// 页面骨架。sidebar=true 时（首页/分类页）为左侧栏 + 内容区的双栏形态，
// ≥1080px 显示侧栏并隐藏顶栏；窄屏与其余页面均为极简顶栏形态。
import site from '../../site.json';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
// 样式经 Astro 打包产出内容哈希文件名——Vercel 对静态资源发 immutable 缓存，
// 固定路径会让老访客拿到旧 CSS（v1.2 上线时踩过），哈希路径每次部署自动失效
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  /** og:type，文章页传 'article'，其余默认 'website' */
  ogType?: string;
  /** 左侧栏形态（首页与分类页） */
  sidebar?: boolean;
}
const { title, description, ogType = 'website', sidebar = false } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang="zh-CN">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{title}</title>
<meta name="description" content={description}>
<link rel="canonical" href={canonical}>
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<meta property="og:title" content={title}>
<meta property="og:description" content={description}>
<meta property="og:type" content={ogType}>
<meta property="og:url" content={canonical}>
<meta property="og:site_name" content={site.title}>
<meta name="twitter:card" content="summary">
<link rel="alternate" type="application/rss+xml" title={site.title} href="/feed.xml">
<link rel="sitemap" href="/sitemap-index.xml">
{/* 深色模式初始化必须内联在 head，防止首屏闪白 */}
<script is:inline>(function(){try{var t=localStorage.getItem('theme')||(window.matchMedia('(prefers-color-scheme: dark)').matches?'dark':'light');document.documentElement.setAttribute('data-theme',t);}catch(e){}})();</script>
</head>
<body>
<div class="progress" aria-hidden="true"><div class="progress__bar"></div></div>
{sidebar ? (
  <div class="shell">
    <Sidebar />
    <div class="content">
      <Header />
      <slot />
      <Footer />
    </div>
  </div>
) : (
  <Fragment>
    <Header />
    <slot />
    <Footer />
  </Fragment>
)}
<script src="../scripts/main.js"></script>
</body>
</html>
