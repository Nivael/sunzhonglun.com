---
// 关于页：内容来自 content/about.md
import { getEntry, render } from 'astro:content';
import Base from '../layouts/Base.astro';
import site from '../../site.json';

const about = await getEntry('pages', 'about');
if (!about) throw new Error('缺少 content/about.md');
const { Content } = await render(about);
---
<Base title={`关于 — ${site.title}`} description={site.description}>
  <article class="post">
    <header class="post-header reveal"><h1>{about.data.title}</h1></header>
    <div class="post-content"><Content /></div>
  </article>
</Base>
