---
import { getCollection, render } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import site from '../../../../site.json';
import {
  categoryNameEn,
  categoryOf,
  dateISO,
  pairEnglishPosts,
  postSlug,
  readingMinutes,
} from '../../../lib/posts';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  const translations = await getCollection('postsEn');
  return pairEnglishPosts(posts, translations).map((pair) => ({
    params: { slug: postSlug(pair.source) },
    props: { pair },
  }));
}

const { pair } = Astro.props;
const { source, translation } = pair;
const { Content } = await render(translation);
const slug = postSlug(source);
---
<Base
  title={`${translation.data.title} — ${site.title}`}
  description={translation.data.excerpt}
  ogType="article"
  lang="en"
  alternatePath={`/posts/${slug}/`}
>
  <article class="post">
    <header class="post-header reveal">
      <h1>{translation.data.title}</h1>
      <div class="post-meta">
        {dateISO(source.data.date)} · <span class="cat">{categoryNameEn(categoryOf(source))}</span> · {readingMinutes(translation.body ?? '')} min read
      </div>
    </header>
    <div class="post-content"><Content /></div>
    <footer class="post-footer"><a class="back" href="/en/">← All writing</a></footer>
  </article>
</Base>
