---
// 分类归档页（v1.4 杂志化）：masthead 为分类名大字 + 篇数，列表为杂志网格（无 feature）
import { getCollection } from 'astro:content';
import PostList from '../../components/PostList.astro';
import Base from '../../layouts/Base.astro';
import site from '../../../site.json';
import { CATEGORIES, categoryBySlug, categoryOf, sortPostsDesc } from '../../lib/posts';

export function getStaticPaths() {
  return CATEGORIES.map((c) => ({ params: { slug: c.slug } }));
}

const { slug } = Astro.params;
const cat = categoryBySlug(slug)!;
const posts = sortPostsDesc(await getCollection('posts')).filter((p) => categoryOf(p) === cat.name);
---
<Base title={`${cat.name} — ${site.title}`} description={`分类「${cat.name}」下的 ${posts.length} 篇文章`} sidebar>
  <section class="hero masthead reveal">
    <p class="masthead-meta">
      <span>分类</span>
      <span>{posts.length} 篇</span>
    </p>
    <h1>{cat.name}</h1>
    <div class="rule-double" aria-hidden="true"></div>
  </section>
  <main class="home-main magazine">
    <PostList posts={posts} />
  </main>
</Base>
