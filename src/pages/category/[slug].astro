---
// 分类归档页：与首页列表同构，hero 为分类名 + 篇数
import { getCollection } from 'astro:content';
import PostList from '../../components/PostList.astro';
import Base from '../../layouts/Base.astro';
import site from '../../../site.json';
import { CATEGORIES, categoryBySlug, categoryOf, sortPostsDesc } from '../../lib/posts';

export function getStaticPaths() {
  return CATEGORIES.map((c) => ({ params: { slug: c.slug } }));
}

const { slug } = Astro.params;
const cat = categoryBySlug(slug)!;
const posts = sortPostsDesc(await getCollection('posts')).filter((p) => categoryOf(p) === cat.name);
---
<Base title={`${cat.name} — ${site.title}`} description={`分类「${cat.name}」下的 ${posts.length} 篇文章`} sidebar>
  <section class="hero reveal">
    <h1>{cat.name}</h1>
    <p>{posts.length} 篇</p>
  </section>
  <main class="home-main">
    <PostList posts={posts} />
  </main>
</Base>
