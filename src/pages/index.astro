---
// 首页：portfolio 形态（侧栏 + hero 一句话 + 最新列表）
import { getCollection } from 'astro:content';
import PostList from '../components/PostList.astro';
import Base from '../layouts/Base.astro';
import site from '../../site.json';
import { sortPostsDesc } from '../lib/posts';

const posts = sortPostsDesc(await getCollection('posts'));
---
<Base title={site.title} description={site.description} sidebar>
  <section class="hero reveal">
    <h1>Hi there, I'm Zhonglun, and <em>I write.</em></h1>
  </section>
  <main class="home-main">
    <PostList posts={posts} />
  </main>
</Base>
