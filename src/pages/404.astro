---
// 404 页：复用 Base 布局，风格与全站一致
import Base from '../layouts/Base.astro';
import site from '../../site.json';
---
<Base title={`页面不存在 — ${site.title}`} description={site.description}>
  <article class="post">
    <header class="post-header reveal">
      <h1>404</h1>
      <div class="post-meta">这一页不存在，或已被移动。</div>
    </header>
    <footer class="post-footer"><a class="back" href="/">← 返回首页</a></footer>
  </article>
</Base>
