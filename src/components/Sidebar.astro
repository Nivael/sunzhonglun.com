---
// 左侧栏：仅首页与分类页使用（PRD §6.3），≥1080px 显示
import { getCollection } from 'astro:content';
import site from '../../site.json';
import { CATEGORIES, categoryOf } from '../lib/posts';
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  lang?: 'zh-CN' | 'en';
}
const { lang = 'zh-CN' } = Astro.props;
const english = lang === 'en';
const posts = await getCollection('posts');
const counts = new Map<string, number>();
for (const p of posts) {
  const c = categoryOf(p);
  counts.set(c, (counts.get(c) ?? 0) + 1);
}
const path = Astro.url.pathname;
---
<aside class="sidebar">
  <div class="side-id">
    <div class="avatar">S</div>
    <div class="name">{site.title}</div>
    <div class="bio">I write.</div>
  </div>
  <nav class="side-nav">
    <div class="side-label">{english ? 'NAVIGATION' : '导航'}</div>
    <a class={path === (english ? '/en/' : '/') ? 'current' : undefined} href={english ? '/en/' : '/'}>
      {english ? 'Writing' : '文章'}
    </a>
    <a href={english ? '/en/about/' : '/about/'}>{english ? 'About' : '关于'}</a>
  </nav>
  {!english && (
    <nav class="side-cats">
      <div class="side-label">分类</div>
      {CATEGORIES.map((c) => (
        <a class={path.startsWith(`/category/${c.slug}`) ? 'current' : undefined} href={`/category/${c.slug}/`}>
          {c.name}<b>{counts.get(c.name) ?? 0}</b>
        </a>
      ))}
    </nav>
  )}
  <div class="side-stats" hidden>
    <div class="side-label">{english ? 'VISITS' : '来访'}</div>
    <div>{english ? 'Visitors ' : '来访 '}<b data-stat="uvTotal"></b>{english ? ' · Today ' : ' 人 · 今日 '}<b data-stat="uvToday"></b></div>
    <div>{english ? 'Views ' : '浏览 '}<b data-stat="pvTotal"></b>{english ? ' · Today ' : ' 次 · 今日 '}<b data-stat="pvToday"></b></div>
  </div>
  <div class="side-foot">
    <a href="mailto:zhonglunsun@gmail.com">zhonglunsun@gmail.com</a>
    <a href="/feed.xml">{english ? 'RSS (Chinese)' : 'RSS'}</a>
    <ThemeToggle lang={lang} />
  </div>
</aside>
