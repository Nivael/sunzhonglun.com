---
// 顶栏：窄屏与文章页的导航（侧栏页面在 ≥1080px 时由 CSS 隐藏它）
import site from '../../site.json';
import LanguageSwitch from './LanguageSwitch.astro';
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  lang?: 'zh-CN' | 'en';
  alternatePath?: string;
}
const { lang = 'zh-CN', alternatePath } = Astro.props;
const english = lang === 'en';
---
<header class="site-header">
  <a class="site-logo" href={english ? '/en/' : '/'}>{site.title}</a>
  <nav>
    <a class="writing-link" href={english ? '/en/' : '/'}>{english ? 'Writing' : '文章'}</a>
    {!english && <a class="categories-link" href="/categories/">分类</a>}
    <a href={english ? '/en/about/' : '/about/'}>{english ? 'About' : '关于'}</a>
    {alternatePath && <LanguageSwitch compact lang={lang} alternatePath={alternatePath} />}
    <ThemeToggle lang={lang} />
  </nav>
  {alternatePath && <LanguageSwitch lang={lang} alternatePath={alternatePath} />}
</header>
